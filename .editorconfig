root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
max_line_length = 120
# Composable functions are PascalCase by Compose convention.
ktlint_function_naming_ignore_when_annotated_with = Composable
# We group small related types per file (e.g. sealed route hierarchies), so the
# "filename must match the single top-level declaration" rule is disabled.
ktlint_standard_filename = disabled

[*.{yml,yaml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
